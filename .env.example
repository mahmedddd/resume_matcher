# ─────────────────────────────────────────────
# Pak-Intern Sentinel — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Required: Get free key at https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Firecrawl fallback scraper (https://firecrawl.dev)
# Free tier: 500 pages/month
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Database URL (SQLite by default, swap for postgres:// for production)
DATABASE_URL=sqlite+aiosqlite:///./pakinter.db

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Scraper settings
SCRAPER_HEADLESS=true
SCRAPER_MAX_PAGES=3
